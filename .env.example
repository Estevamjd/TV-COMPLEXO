# Banco de dados PostgreSQL (Neon.tech ou outro)
DATABASE_URL="postgresql://usuario:senha@host:5432/nomedb?sslmode=require"

# JWT — use uma chave aleatória de 64+ caracteres (ex: openssl rand -base64 64)
JWT_SECRET="gere_uma_chave_aleatoria_forte_com_64_caracteres_ou_mais"

# Admin — credenciais do painel administrativo
ADMIN_EMAIL="admin@tvcomplexo.com.br"
ADMIN_USER="admin"
# Gere o hash com: node scripts/generate-password-hash.js "sua_senha_forte"
ADMIN_PASSWORD_HASH="$2a$12$..."

# Vercel Blob Storage (para uploads de thumbnails)
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# YouTube Automation (Vercel Cron)
YOUTUBE_CHANNEL_ID="UCxxxxxxxxxxxxxxxxxxxxxxxxx"
CRON_SECRET="chave_secreta_para_proteger_o_cron"

# Webhook Secret (para integração com n8n)
WEBHOOK_SECRET="chave_secreta_para_webhooks"
